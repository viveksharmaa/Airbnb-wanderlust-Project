<% layout("layouts/boilerplate") %>

    <div class="row">
        <h1 class="col-8 offset-2">Signup on wonderlust </h1>
        <div class="col-8 offset-2">
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label><br>
                    <input name="username" id="username" type="text" class="form-control" required/>
                    <div class="valid-feedback">Loooks good!</div>
                    <div class="invalid-feedback">plese enter username</div>
                    
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label><br>
                    <input name="email" id="email" type="email" class="form-control" required/>
                    
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label><br>
                    <input name="password" id="password" type="apssword" class="form-control" required/>
                    
                </div>
                <button class="btn btn-success mb-3">SignUp</button>
            </form>
        </div>
    </div>